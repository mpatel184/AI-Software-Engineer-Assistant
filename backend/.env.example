# --- App ---
ENVIRONMENT=development
DEBUG=true
APP_NAME="AI Software Engineer Assistant"

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Async DSN (asyncpg) used by the API/worker.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_swe
DB_ECHO=false

# --- Redis (Celery broker + cache + rate limit) ---
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Claude / AI ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# --- Vector store (ChromaDB) ---
CHROMA_HOST=chroma
CHROMA_PORT=8000
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Repository storage ---
REPO_STORAGE_PATH=/data/repos
REPORT_STORAGE_PATH=/data/reports
MAX_REPO_SIZE_MB=500

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60
