# --- App ---
ENVIRONMENT=development
DEBUG=true
APP_NAME="AI Software Engineer Assistant"

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Async DSN (asyncpg) used by the API/worker.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_swe
DB_ECHO=false

# --- Redis (Celery broker + cache + rate limit) ---
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM (local, model-agnostic) ---
# Default: Qwen3-Coder-30B served locally through an OpenAI-compatible API.
# Swap the inference backend by changing LLM_BASE_URL + LLM_STRUCTURED_MODE only:
#   vLLM      -> http://inference:8000/v1   | LLM_STRUCTURED_MODE=guided_json
#   Ollama    -> http://inference:11434/v1  | LLM_STRUCTURED_MODE=ollama_format
#   LM Studio -> http://host.docker.internal:1234/v1 | LLM_STRUCTURED_MODE=json_schema
LLM_PROVIDER=qwen
LLM_BASE_URL=http://inference:8000/v1
LLM_API_KEY=local
LLM_MODEL=Qwen3-Coder-30B-A3B-Instruct
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_CONTEXT_SIZE=131072
LLM_STRUCTURED_MODE=guided_json
LLM_REQUEST_TIMEOUT=300

# --- Vector store (ChromaDB) & embeddings (local) ---
CHROMA_HOST=chroma
CHROMA_PORT=8000
# Code-aware, local embeddings. Changing this changes the vector dimension and
# requires re-indexing existing repositories (Ollama users: `ollama pull nomic-embed-text`).
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
RETRIEVAL_TOP_K=6

# --- Repository storage ---
REPO_STORAGE_PATH=/data/repos
REPORT_STORAGE_PATH=/data/reports
MAX_REPO_SIZE_MB=500

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60
