# --- App ---
ENVIRONMENT=development
DEBUG=true
APP_NAME="AI Software Engineer Assistant"

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Async DSN (asyncpg) used by the API/worker.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_swe
DB_ECHO=false

# --- Redis (Celery broker + cache + rate limit) ---
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────────────────────────────────────
# LLM — Primary: Gemini 2.5 Flash (FREE via Google AI Studio)
#   Get your free API key at: https://aistudio.google.com
#   No credit card required for the free tier.
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=your_google_aistudio_api_key_here
LLM_STRUCTURED_MODE=json_schema
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=120

# ─────────────────────────────────────────────────────────────────────────────
# LLM — Fallback: Z.ai GLM-4.7-Flash (completely free, no card needed)
#   Get your free API key at: https://z.ai  (BigModel / ZhipuAI platform)
#   To switch: uncomment these and comment-out the Gemini block above.
# ─────────────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4.7-flash
# LLM_API_KEY=your_zai_api_key_here
# LLM_STRUCTURED_MODE=json_schema

# ─────────────────────────────────────────────────────────────────────────────
# Embeddings — Local (sentence-transformers) or Remote (OpenAI-compatible)
#   Set EMBEDDING_PROVIDER=local for local sentence-transformers model
#   Set EMBEDDING_PROVIDER=openai_compat for remote API (default)
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=openai_compat
# Local provider settings
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# LOCAL_EMBEDDING_DEVICE=   # optional: 'cpu', 'cuda', etc. (None = auto-detect)
# LOCAL_EMBEDDING_NORMALIZE=true  # optional: L2-normalize embeddings (default: true)
# Remote provider settings (OpenAI-compatible /embeddings endpoint)
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
EMBEDDING_MODEL=text-embedding-004
# EMBEDDING_API_KEY=   # leave blank to reuse LLM_API_KEY automatically

# --- Vector store (ChromaDB) ---
CHROMA_HOST=chroma
CHROMA_PORT=8000
RETRIEVAL_TOP_K=6

# --- Repository storage ---
REPO_STORAGE_PATH=/data/repos
REPORT_STORAGE_PATH=/data/reports
MAX_REPO_SIZE_MB=500

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60
